PORT=4000
DATABASE_URL=postgresql://postgres:postgresql@localhost:5432/giveaway
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# Run schema alignment on API start (default: true). Set false if you manage migrations separately.
RUN_MIGRATIONS_ON_START=true
# Fail startup if migrations fail (recommended in production after first deploy)
# REQUIRE_MIGRATIONS=true

# Admin seed (used on first migrate)
ADMIN_EMAIL=admin@giveaway.local
ADMIN_PASSWORD=admin123

# SMTP (optional — emails log to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@giveaway.local
